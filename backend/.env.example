# Copy to .env and adjust as needed.

ENVIRONMENT=dev
PORT=8080

# Local Supabase Postgres (printed by `supabase status` as "DB URL").
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Base URL of the local Supabase stack (printed by `supabase status` as "Project URL").
# Access tokens are verified against <SUPABASE_URL>/auth/v1/.well-known/jwks.json
SUPABASE_URL=http://127.0.0.1:54321

# Comma-separated list of origins allowed by CORS.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
